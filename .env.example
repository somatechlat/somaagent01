# SomaStack Environment Configuration
# Copy to .env and customize

# ==========================================================================
# ENVIRONMENT
# ==========================================================================
ENVIRONMENT=development

# ==========================================================================
# DATABASE
# ==========================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=somaagent
POSTGRES_PORT=5432

# ==========================================================================
# CACHE
# ==========================================================================
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ==========================================================================
# MESSAGE BROKER
# ==========================================================================
KAFKA_PORT=9092

# ==========================================================================
# VECTOR DATABASE
# ==========================================================================
MILVUS_PORT=19530

# ==========================================================================
# AUTHORIZATION
# ==========================================================================
SPICEDB_TOKEN=
OPA_PORT=8181

# ==========================================================================
# JWT / AUTH
# ==========================================================================
JWT_SECRET=
JWT_ALGORITHM=HS256

# ==========================================================================
# SOMAAGENT01 REQUIRED ENVIRONMENT VARIABLES
# (These are required by services/gateway/settings.py on startup)
# ==========================================================================
SA01_DB_DSN=postgresql://postgres:<DB_PASSWORD>@localhost:5432/somaagent
SA01_REDIS_URL=redis://localhost:6379
SA01_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SA01_SOMA_BASE_URL=http://localhost:8000
SA01_OPA_URL=http://localhost:8181/v1/data/soma
SA01_KEYCLOAK_URL=http://localhost:8080
SA01_JWT_SECRET=
SA01_ALLOWED_HOSTS=localhost,127.0.0.1,*
SA01_AUTH_REQUIRED=true

# ==========================================================================
# LLM PROVIDERS
# ==========================================================================
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ==========================================================================
# CONFIDENCE SCORING
# ==========================================================================
CONFIDENCE_ENABLED=true
CONFIDENCE_AGGREGATION=average

# ==========================================================================
# GOOGLE OAUTH (for SSO)
# ==========================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
